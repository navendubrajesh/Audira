# Audira.run — environment template (copy to .env, never commit secrets)
# Frontend (Vercel)
NEXT_PUBLIC_API_URL=http://localhost:8000

# API (Render Web Service)
DATABASE_URL=postgresql+asyncpg://audira:audira@localhost:5432/audira
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=["http://localhost:3000"]

# Object storage — Cloudflare R2 or AWS S3 (required day one)
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=audira-artifacts
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=

# GPU inference tier — TRIBE v2 (facebook/tribev2 on Hugging Face)
# Point at services/inference/tribev2 when deployed on Modal/RunPod/GPU VM
INFERENCE_BASE_URL=
INFERENCE_API_KEY=
INFERENCE_MONTHLY_COST_CAP_USD=500

# GPU service only (not on Render/Vercel)
HF_TOKEN=
TRIBE_CACHE_DIR=/cache/tribev2

# Auth (FR-E17-1)
AUTH_MODE=development
JWT_SECRET=change-me-in-production-min-32-characters
WEB_APP_URL=http://localhost:3000

# WorkOS — SSO + SCIM + social OAuth (FR-E17-1)
# Enable Google, Apple, GitHub, and LinkedIn in WorkOS Dashboard → Authentication → OAuth providers
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://localhost:8000/auth/callback
WORKOS_WEBHOOK_SECRET=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
